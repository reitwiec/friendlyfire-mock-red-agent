{
  "sdkVersion": "ff-next",
  "kind": "red",
  "name": "Mock Browser Red Agent",
  "description": "Deterministic non-LLM red agent for backend MVP end-to-end verification.",
  "category": "unauthorized_data_access",
  "minSupportedTier": "starter",
  "entrypoint": "./index.mjs",
  "scopes": [
    "http.request",
    "memory.set",
    "evidence.record",
    "browser.goto",
    "browser.screenshot",
    "browser.fill",
    "browser.click",
    "browser.waitFor",
    "browser.extractText",
    "browser.currentUrl"
  ],
  "capabilities": {
    "http": true,
    "memory": true,
    "credentials": false,
    "evidence": true,
    "browser": true
  },
  "build": {
    "dockerfile": "Dockerfile"
  }
}
